#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = ["inquirer"]
# ///
"""
manage the pretalx plugins I maintain.

this tool owns the canonical list of maintained plugins and their locations
(PLUGIN_PATHS below).

subcommands:
  list             print each maintained plugin and its location
  go <plugin>      print a named plugin's dir to cd into (the fish wrapper cds)
  all <cmd...>     run a command in every plugin repo, report success per repo
  status           git status for every plugin: clean/dirty, push state, HEAD
  next             print the next plugin dir to cd into; if not currently in a
                   plugin, print the first one (the fish wrapper does the cd)
  install          install every plugin into pretalx via `just install-plugin`
  release [plugin] interactive per-plugin PyPI release loop (via ,pydist),
                   keeping pretalx-com's plugin_versions.py in sync

the cookiecutter template is skipped by default (it isn't a releasable plugin);
pass -c/--cookiecutter before the subcommand to include it.
"""

import os
import re
import subprocess
import sys
import tomllib
from pathlib import Path

PRETALX = Path.home() / "src" / "pretalx" / "main"

PLUGIN_PATHS = [
    "src/local/pretalx-com",
    "src/local/pretalx-downstream",
    "src/local/pretalx-friendlycaptcha",
    "src/local/pretalx-fontpack-free",
    "src/local/pretalx-media-ccc-de",
    "src/local/pretalx-pages",
    "src/local/pretalx-public-voting",
    "src/local/pretalx-salesforce",
    "src/local/pretalx-venueless",
    "src/local/pretalx-vimeo",
    "src/local/pretalx-youtube",
    "src/local/pretalx-broadcast-tools",
]
COOKIECUTTER_PATH = "src/local/pretalx-plugin-cookiecutter"


CODES = {
    "{B}": "\033[1m", "{D}": "\033[2m", "{R}": "\033[0m",
    "{G}": "\033[32m", "{Y}": "\033[33m", "{r}": "\033[31m",
}


def out(s):
    tty = sys.stdout.isatty()
    for k, v in CODES.items():
        s = s.replace(k, v if tty else "")
    return s


def vis(s):
    for k in CODES:
        s = s.replace(k, "")
    return len(s)


def pad(s, width):
    return s + " " * max(0, width - vis(s))


def warn(msg):
    print(out(f"{{Y}}warning:{{R}} {msg}"), file=sys.stderr)


def die(msg, code=1):
    print(out(f"{{r}}error:{{R}} {msg}"), file=sys.stderr)
    sys.exit(code)


def git(repo, *args):
    proc = subprocess.run(
        ["git", "-C", str(repo), *args],
        capture_output=True, text=True,
    )
    return proc.returncode, proc.stdout


def git_toplevel(path):
    code, top = git(path, "rev-parse", "--show-toplevel")
    return Path(top.strip()) if code == 0 and top.strip() else None


def plugin_paths(cookiecutter=False):
    return PLUGIN_PATHS + ([COOKIECUTTER_PATH] if cookiecutter else [])


def plugin_repos(cookiecutter=False):
    repos = []
    for rel in plugin_paths(cookiecutter):
        top = git_toplevel(PRETALX / rel)
        if top is None:
            warn(f"not a git repo, skipping: {rel}")
            continue
        repos.append(top)
    if not repos:
        die("none of the maintained plugin repos were found")
    return repos


def cmd_list(argv, cookiecutter=False):
    rels = plugin_paths(cookiecutter)
    width = max(len(Path(rel).name) for rel in rels)
    for rel in rels:
        name = pad(f"{{B}}{Path(rel).name}{{R}}", width)
        print(out(f"{name}  {{D}}{PRETALX / rel}{{R}}"))


def resolve_plugin(query, cookiecutter=True):
    by_name = {Path(rel).name: rel for rel in plugin_paths(cookiecutter=cookiecutter)}
    names = list(by_name)
    if query in names:
        match = query
    elif f"pretalx-{query}" in names:
        match = f"pretalx-{query}"
    else:
        hits = [n for n in names if n.startswith(query)] or [n for n in names if query in n]
        if len(hits) == 1:
            match = hits[0]
        elif not hits:
            die(f"no plugin matches: {query}")
        else:
            die(f"ambiguous: {query} matches {', '.join(hits)}")
    return match, by_name[match]


def cmd_go(argv, cookiecutter=False):
    if len(argv) != 1:
        die("usage: ,pplugin go <plugin>")
    match, rel = resolve_plugin(argv[0])
    target = PRETALX / rel
    if not target.is_dir():
        die(f"plugin dir missing: {target}")
    print(out(f"{{D}}→ {match}{{R}}"), file=sys.stderr)
    print(target)


def clean_env():
    # our shebang runs this under `uv run`, which exports VIRTUAL_ENV (and a
    # recursion guard) pointing at this script's own throwaway env. strip them
    # so child `just`/`uv` commands use each plugin's real .venv instead of
    # warning about the mismatch.
    return {
        k: v for k, v in os.environ.items()
        if k not in ("VIRTUAL_ENV", "UV_RUN_RECURSION_DEPTH")
    }


def cmd_all(argv, cookiecutter=False):
    if not argv:
        die("usage: ,pplugin all <command...>")
    env = clean_env()
    repos = plugin_repos(cookiecutter)
    failures = []
    for repo in repos:
        proc = subprocess.run(
            argv, cwd=repo, env=env, text=True,
            stdout=subprocess.PIPE, stderr=subprocess.STDOUT,
        )
        ok = proc.returncode == 0
        mark = "{G}✓{R}" if ok else "{r}✗{R}"
        suffix = "" if ok else out(f"  {{D}}(exit {proc.returncode}){{R}}")
        print(out(f"{mark} {{B}}{repo.name}{{R}}") + suffix)
        body = proc.stdout.rstrip()
        if body:
            for line in body.splitlines():
                print(f"    {line}")
        if not ok:
            failures.append(repo.name)
    total = len(repos)
    if failures:
        print(out(f"\n{{r}}{len(failures)}/{total} failed:{{R}} {', '.join(failures)}"))
        sys.exit(1)
    print(out(f"\n{{G}}all {total} ok{{R}}"))


def cmd_install(argv, cookiecutter=False):
    env = clean_env()
    rels = plugin_paths(cookiecutter=False)
    failures = []
    for rel in rels:
        path = PRETALX / rel
        name = Path(rel).name
        if not path.is_dir():
            warn(f"plugin dir missing, skipping: {rel}")
            failures.append(name)
            continue
        proc = subprocess.run(
            ["just", "install-plugin", str(path)],
            cwd=PRETALX, env=env, text=True,
            stdout=subprocess.PIPE, stderr=subprocess.STDOUT,
        )
        ok = proc.returncode == 0
        mark = "{G}✓{R}" if ok else "{r}✗{R}"
        suffix = "" if ok else out(f"  {{D}}(exit {proc.returncode}){{R}}")
        print(out(f"{mark} {{B}}{name}{{R}}") + suffix)
        body = proc.stdout.rstrip()
        if body:
            for line in body.splitlines():
                print(f"    {line}")
        if not ok:
            failures.append(name)
    total = len(rels)
    if failures:
        print(out(f"\n{{r}}{len(failures)}/{total} failed:{{R}} {', '.join(failures)}"))
        sys.exit(1)
    print(out(f"\n{{G}}all {total} installed{{R}}"))


def repo_status(repo):
    _, porcelain = git(repo, "status", "--porcelain=2", "--branch")
    head = upstream = None
    ahead = behind = 0
    changes = 0
    for line in porcelain.splitlines():
        if line.startswith("# branch.head "):
            head = line.split(" ", 2)[2]
        elif line.startswith("# branch.upstream "):
            upstream = line.split(" ", 2)[2]
        elif line.startswith("# branch.ab "):
            parts = line.split(" ", 2)[2].split()
            ahead, behind = int(parts[0]), int(parts[1])
        elif line and not line.startswith("#"):
            changes += 1
    sep = "\x1f"
    _, log = git(repo, "log", "-1", f"--format=%h{sep}%D{sep}%s")
    short, decor, subject = (log.strip().split(sep) + ["", "", ""])[:3]
    return {
        "head": head, "upstream": upstream, "ahead": ahead, "behind": behind,
        "changes": changes, "short": short, "decor": decor, "subject": subject,
    }


def cmd_status(argv, cookiecutter=False):
    repos = plugin_repos(cookiecutter)
    width = max(len(r.name) for r in repos)
    for repo in repos:
        s = repo_status(repo)

        if s["changes"]:
            dot = "{Y}●{R}"
            state = f"{{Y}}dirty ({s['changes']}){{R}}"
        else:
            dot = "{G}○{R}"
            state = "{G}clean{R}"

        if not s["upstream"]:
            push = "{Y}no upstream{R}"
        elif not s["ahead"] and not s["behind"]:
            push = "{D}up to date{R}"
        else:
            bits = []
            if s["ahead"]:
                bits.append(f"↑{s['ahead']}")
            if s["behind"]:
                bits.append(f"{{r}}↓{s['behind']}{{R}}")
            push = " ".join(bits)

        tags = [t[5:] for t in s["decor"].split(", ") if t.startswith("tag: ")]
        tag_str = f" {{G}}[{', '.join(tags)}]{{R}}" if tags else ""
        head = f"{{D}}{s['short']}{{R}}{tag_str} {s['subject']}"

        name = pad(f"{{B}}{repo.name}{{R}}", width)
        line = f"{dot} {name}  {pad(state, 12)}  {pad(push, 14)}  {head}"
        print(out(line))


def cmd_next(argv, cookiecutter=False):
    repos = plugin_repos(cookiecutter)
    here = git_toplevel(Path.cwd())
    idx = None
    if here is not None:
        for i, repo in enumerate(repos):
            if repo == here:
                idx = i
                break
    target = repos[0] if idx is None else repos[(idx + 1) % len(repos)]
    where = "first" if idx is None else "next"
    print(out(f"{{D}}→ {where}: {target.name}{{R}}"), file=sys.stderr)
    print(target)


PLUGIN_VERSIONS = PRETALX / "src/local/pretalx-com/pretalx_com/plugin_versions.py"

VERSION_RE = re.compile(r'__version__\s*=\s*["\']([^"\']+)["\']')
ENTRY_RE = re.compile(r'^(\s*)"([^"]+)"\s*:\s*"[^"]*",\s*$')


def find_init(repo):
    # same discovery as ,pydist's find_init(): every __init__.py mentioning
    # __version__, shallowest wins. the plugin's own package sits far above the
    # .venv site-packages copies, so depth alone picks the right one.
    candidates = [
        p for p in repo.rglob("__init__.py")
        if "__version__" in p.read_text(errors="ignore")
    ]
    if not candidates:
        return None
    return min(candidates, key=lambda p: (len(p.relative_to(repo).parts), str(p)))


def read_version(repo):
    init = find_init(repo)
    if init is None:
        return None
    m = VERSION_RE.search(init.read_text(errors="ignore"))
    return m.group(1) if m else None


def read_module_name(repo):
    try:
        data = tomllib.loads((repo / "pyproject.toml").read_text())
        entry_points = data["project"]["entry-points"]["pretalx.plugin"]
    except (OSError, tomllib.TOMLDecodeError, KeyError):
        return None
    if not entry_points:
        return None
    return next(iter(entry_points))


def update_plugin_versions(module, version):
    text = PLUGIN_VERSIONS.read_text()
    lines = text.splitlines(keepends=True)

    for i, line in enumerate(lines):
        m = ENTRY_RE.match(line)
        if m and m.group(2) == module:
            lines[i] = f'{m.group(1)}"{module}": "{version}",\n'
            PLUGIN_VERSIONS.write_text("".join(lines))
            return

    # no entry yet: insert in sorted position, matching surrounding indent.
    indent, insert_at, last_entry = "    ", None, None
    for i, line in enumerate(lines):
        m = ENTRY_RE.match(line)
        if m:
            indent, last_entry = m.group(1), i
            if insert_at is None and m.group(2) > module:
                insert_at = i
    if insert_at is None:
        insert_at = last_entry + 1 if last_entry is not None else len(lines)
    lines.insert(insert_at, f'{indent}"{module}": "{version}",\n')
    PLUGIN_VERSIONS.write_text("".join(lines))


def cmd_release(argv, cookiecutter=False):
    # imported lazily so the hot go/next/status paths (used by fish cd
    # wrappers) don't pay inquirer's import cost.
    import inquirer

    pydist = Path(__file__).resolve().parent / ",pydist"
    if argv:
        _, rel = resolve_plugin(argv[0])
        rels = [rel]
    else:
        rels = plugin_paths(cookiecutter=False)
    env = clean_env()

    released, skipped, failed = [], [], []
    try:
        for rel in rels:
            name = Path(rel).name
            repo = git_toplevel(PRETALX / rel)
            if repo is None:
                warn(f"not a git repo, skipping: {rel}")
                skipped.append((name, "not a git repo"))
                continue

            version = read_version(repo)
            if version is None:
                print(out(f"{{r}}✗ {name}: no __init__.py with __version__ found{{R}}"))
                failed.append((name, "no __version__"))
                continue
            if version == "0.0.0":
                print(out(f"{{D}}○ {name}: no public package, skipping{{R}}"))
                skipped.append((name, "no public package"))
                continue

            code, tag_out = git(repo, "describe", "--tags", "--abbrev=0")
            tag = tag_out.strip() if code == 0 else None
            if tag:
                _, log_out = git(repo, "log", f"{tag}..HEAD", "--oneline")
            else:
                _, log_out = git(repo, "log", "--oneline")
            commits = log_out.strip()
            if not commits:
                print(out(f"{{D}}○ {name}: no changes since v{version}, skipping{{R}}"))
                skipped.append((name, f"no changes since v{version}"))
                continue

            print()
            last = tag or "none"
            print(out(f"{{B}}{name}{{R}}  {{D}}v{version}  (last tag: {last}){{R}}"))
            for line in commits.splitlines():
                print(out(f"  {{D}}{line}{{R}}"))

            ans = inquirer.list_input(
                f"Bump {name} (v{version})",
                choices=["major", "minor", "patch", "skip"],
                default="skip",
            )

            if ans in (None, "skip"):
                print(out(f"{{D}}○ {name}: skipped{{R}}"))
                skipped.append((name, "manual skip"))
                continue

            proc = subprocess.run([str(pydist), ans], cwd=repo, env=env)
            if proc.returncode != 0:
                print(out(f"{{r}}✗ {name}: release failed{{R}}"))
                failed.append((name, "release failed"))
                continue

            # source of truth for the released version is the bumped
            # __init__.py, not ,pydist's stdout — re-read it, don't parse output.
            new_version = read_version(repo)
            module = read_module_name(repo)
            if module is None:
                print(out(
                    f"{{r}}✗ {name}: could not read module name from pyproject.toml, "
                    f'fix its [project.entry-points."pretalx.plugin"] section — '
                    f"plugin_versions.py NOT updated{{R}}"
                ))
                failed.append((name, "released, plugin_versions.py not updated"))
                continue

            update_plugin_versions(module, new_version)
            print(out(f"{{G}}✓ {name}: released v{new_version}{{R}}"))
            released.append((name, new_version))
    except KeyboardInterrupt:
        print(out("\n{Y}interrupted{R}"))

    print(out("\n{B}release summary{R}"))
    for name, ver in released:
        print(out(f"  {{G}}✓{{R}} {name}: released v{ver}"))
    for name, reason in skipped:
        print(out(f"  {{D}}○ {name}: skipped ({reason}){{R}}"))
    for name, reason in failed:
        print(out(f"  {{r}}✗{{R}} {name}: {reason}"))
    if not (released or skipped or failed):
        print(out("  {D}nothing to do{R}"))
    if released:
        rel = "src/local/pretalx-com/pretalx_com/plugin_versions.py"
        print(out(
            f"\n{{Y}}reminder:{{R}} {rel} has pending uncommitted changes — "
            f"review them before the next pretalx-com deploy."
        ))


def main():
    args = sys.argv[1:]
    cookiecutter = False
    while args and args[0] in ("-c", "--cookiecutter"):
        cookiecutter = True
        args = args[1:]
    usage = "usage: ,pplugin [-c] {list|go <plugin>|all <cmd...>|status|next|install|release [plugin]}"
    if not args:
        die(usage)
    cmd, rest = args[0], args[1:]
    if cmd in ("-h", "--help", "help"):
        print(__doc__.strip())
        return
    handlers = {
        "list": cmd_list, "go": cmd_go, "all": cmd_all,
        "status": cmd_status, "next": cmd_next, "install": cmd_install,
        "release": cmd_release,
    }
    handler = handlers.get(cmd)
    if handler is None:
        die(f"unknown subcommand: {cmd}\n{usage}")
    handler(rest, cookiecutter)


if __name__ == "__main__":
    main()
